# Terraform
**/.terraform/
# .terraform.lock.hcl is gitignored in the TEMPLATE repo only (to avoid
# churn from local/CI `terraform init` in this repo). `init-fleet.sh`
# removes this line on adoption so adopter repos commit lock files for
# reproducibility (HashiCorp's recommendation).
**/.terraform.lock.hcl
**/.terraform.lock.hcl.bak
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# `clusters/_fleet.yaml` is a template-repo scratch file — rendered by
# `init/` on first adopter run, then edited in place. In adopter repos
# it is the single source of truth and IS committed; `init-fleet.sh`
# strips this line during self-cleanup so adopter repos commit it. In
# the *template* repo it must never be committed.
/clusters/_fleet.yaml

# Generated tfvars (see terraform/config-loader/load.sh and .github/workflows/tf-apply.yaml)
# Stage 1 per-cluster merged config is generated at CI time and never committed.
**/terraform.tfvars.json
**/stage2.auto.tfvars.json
!**/examples/**/terraform.tfvars.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*~

# Secrets — nothing here should ever be committed; belt and braces.
*.pem
*.key
!**/testdata/**/*.pem
.env
.envrc.local

# Template-adoption artifacts. `.fleet-initialized` is intentionally NOT
# ignored — it's committed by the adopter to record initialization.
.fleet-bootstrap/

# init-gh-apps.sh artifacts (PLAN §16.4). `.gh-apps.state.json` carries
# the full GitHub App payload (IDs, client IDs, PEMs, webhook secrets
# for all three Apps); the per-module overlay carries only the
# `fleet-runners` PEM for `bootstrap/fleet`. Neither is ever committed.
/.gh-apps.state.json
/terraform/bootstrap/fleet/.gh-apps.auto.tfvars
